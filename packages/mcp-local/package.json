{
  "name": "@design-mode/mcp-local",
  "version": "1.5.0",
  "description": "Local MCP companion server — bridges the Design Mode extension to coding agents over a localhost WebSocket.",
  "license": "MIT",
  "bin": {
    "design-mode-mcp": "./dist/bin/cli.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/bin/cli.ts",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' tsc",
    "start": "npx tsx src/bin/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@design-mode/shared": "*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ws": "^8.21.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
