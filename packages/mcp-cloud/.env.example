# Vercel Marketplace Redis (Upstash) integration. One install on the
# project's Storage tab auto-injects these. Names below are exactly what
# the integration sets; keep them out of the repo for local dev.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Server-side secret used to sign tokens. Long, random, never committed.
# Generate with: openssl rand -hex 32
DM_TOKEN_SECRET=

# Optional. Per-tenant tool calls allowed per UTC day. Defaults to 25 if
# unset. The cap is the only cost-control lever — there is no idle
# disconnect or polling slowdown, so user-facing latency stays sharp.
DM_DAILY_QUOTA=25
