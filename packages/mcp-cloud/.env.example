# Vercel KV — single integration powers tokens, the inbound queue,
# response correlation, and the daily quota counter. Add it from the
# Vercel project's Storage tab; the env vars below are auto-injected by
# the integration. Keep them out of the repo.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Server-side secret used to sign tokens. Long, random, never committed.
# Generate with: openssl rand -hex 32
DM_TOKEN_SECRET=

# Optional. Per-tenant tool calls allowed per UTC day. Defaults to 25 if
# unset. The cap is the only cost-control lever — there is no idle
# disconnect or polling slowdown, so user-facing latency stays sharp.
DM_DAILY_QUOTA=25
