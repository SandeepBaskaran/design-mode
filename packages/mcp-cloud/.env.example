# Vercel Marketplace Redis integration auto-injects this on production.
# Standard Redis connection URI (rediss://default:password@host:port).
# Keep it out of the repo; for local dev paste the project's Production
# value into .env.local.
REDIS_URL=

# Server-side secret used to sign tokens. Long, random, never committed.
# Generate with: openssl rand -hex 32
DM_TOKEN_SECRET=

# Optional. Per-tenant tool calls allowed per UTC day. Defaults to 25 if
# unset. The cap is the only cost-control lever — there is no idle
# disconnect or polling slowdown, so user-facing latency stays sharp.
DM_DAILY_QUOTA=25
