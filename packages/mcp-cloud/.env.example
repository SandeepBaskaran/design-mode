# Upstash Redis (Streams + general KV)
# Provision at https://upstash.com → Create Database → REST API tab.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel KV (token store). Provisioned automatically when you add the
# Vercel KV integration to this project; the env vars below are populated
# from the integration. Keep them out of the repo.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Server-side secret used to sign tokens. Long, random, never committed.
# Generate with: openssl rand -hex 32
DM_TOKEN_SECRET=

# Optional. Per-tenant tool calls allowed per UTC day. Defaults to 25 if
# unset. The cap is the only cost-control lever — there is no idle
# disconnect or polling slowdown, so user-facing latency stays sharp.
DM_DAILY_QUOTA=25
